<Window x:Class="PR9.Task2_Counter"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Задание 2: Счётчик в фоновом режиме"
        Height="220" Width="380"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <StackPanel Margin="20" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
            <Button x:Name="btnStart" Content="Start" Width="90" Height="36" Margin="0,0,10,0" Click="Start_Click"/>
            <Button x:Name="btnStop"  Content="Stop"  Width="90" Height="36" IsEnabled="False" Click="Stop_Click"/>
        </StackPanel>

        <Label x:Name="lblCount"
               Content="0"
               FontSize="36" FontWeight="Bold"
               HorizontalAlignment="Center"
               Margin="0,0,0,16"/>

        <ProgressBar x:Name="progressBar"
                     Height="20"
                     Minimum="0" Maximum="1000000"
                     Value="0"/>
    </StackPanel>
</Window>
