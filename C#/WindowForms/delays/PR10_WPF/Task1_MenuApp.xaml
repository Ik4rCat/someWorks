<Window x:Class="PR10.Task1_MenuApp"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Задание 1: Меню + Toolbar + StatusBar"
        Height="420" Width="600"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- Меню -->
        <Menu DockPanel.Dock="Top" Background="White" BorderBrush="Navy" BorderThickness="0,0,0,1">
            <MenuItem Header="_Фон">
                <MenuItem Header="Красный"   Tag="Red"        Click="BgColor_Click" MouseEnter="MenuItem_MouseEnter" MouseLeave="MenuItem_MouseLeave"/>
                <MenuItem Header="Синий"     Tag="LightBlue"  Click="BgColor_Click" MouseEnter="MenuItem_MouseEnter" MouseLeave="MenuItem_MouseLeave"/>
                <MenuItem Header="Зелёный"   Tag="LightGreen" Click="BgColor_Click" MouseEnter="MenuItem_MouseEnter" MouseLeave="MenuItem_MouseLeave"/>
                <MenuItem Header="Белый"     Tag="White"      Click="BgColor_Click" MouseEnter="MenuItem_MouseEnter" MouseLeave="MenuItem_MouseLeave"/>
                <Separator/>
                <MenuItem Header="По умолчанию" Tag="Default"  Click="BgColor_Click" MouseEnter="MenuItem_MouseEnter" MouseLeave="MenuItem_MouseLeave"/>
            </MenuItem>
            <MenuItem Header="_О программе" Click="About_Click" MouseEnter="MenuItem_MouseEnter" MouseLeave="MenuItem_MouseLeave"/>
            <MenuItem Header="_Закрыть"     Click="Close_Click" MouseEnter="MenuItem_MouseEnter" MouseLeave="MenuItem_MouseLeave"/>
        </Menu>

        <!-- Toolbar -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Tag="Red"        Click="BgColor_Click" ToolTip="Красный фон"
                        MouseEnter="ToolBtn_MouseEnter" MouseLeave="ToolBtn_MouseLeave">
                    <Rectangle Width="20" Height="16" Fill="Red"/>
                </Button>
                <Button Tag="LightBlue"  Click="BgColor_Click" ToolTip="Синий фон"
                        MouseEnter="ToolBtn_MouseEnter" MouseLeave="ToolBtn_MouseLeave">
                    <Rectangle Width="20" Height="16" Fill="LightBlue"/>
                </Button>
                <Button Tag="LightGreen" Click="BgColor_Click" ToolTip="Зелёный фон"
                        MouseEnter="ToolBtn_MouseEnter" MouseLeave="ToolBtn_MouseLeave">
                    <Rectangle Width="20" Height="16" Fill="LightGreen"/>
                </Button>
                <Button Tag="White"      Click="BgColor_Click" ToolTip="Белый фон"
                        MouseEnter="ToolBtn_MouseEnter" MouseLeave="ToolBtn_MouseLeave">
                    <Rectangle Width="20" Height="16" Fill="White" Stroke="Gray" StrokeThickness="1"/>
                </Button>
                <Separator/>
                <Button Click="About_Click" ToolTip="О программе"
                        MouseEnter="ToolBtn_MouseEnter" MouseLeave="ToolBtn_MouseLeave">
                    <TextBlock Text="?" FontWeight="Bold" FontSize="14" Width="20" TextAlignment="Center"/>
                </Button>
                <Button Click="Close_Click" ToolTip="Закрыть"
                        MouseEnter="ToolBtn_MouseEnter" MouseLeave="ToolBtn_MouseLeave">
                    <TextBlock Text="✕" FontSize="12" Width="20" TextAlignment="Center"/>
                </Button>
            </ToolBar>
        </ToolBarTray>

        <!-- StatusBar -->
        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock x:Name="statusText" Text="Готово"/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="statusRight" Text="ПР10 — Задание 1"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Основной контент -->
        <Grid x:Name="mainGrid" Background="White">
            <TextBlock Text="Используйте меню или панель инструментов&#10;для изменения цвета фона."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="16" Foreground="Gray" TextAlignment="Center"/>
        </Grid>
    </DockPanel>
</Window>
