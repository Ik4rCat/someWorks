<Page x:Class="PR11.PageStudent.PageAccountStudent"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Окно ученика"
      Height="350" Width="800">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
        <TextBlock x:Name="lblWelcome"
                   FontSize="20" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,24"
                   TextWrapping="Wrap" TextAlignment="Center"/>
        <TextBlock Text="Добро пожаловать в личный кабинет ученика!"
                   FontSize="15" HorizontalAlignment="Center" Margin="0,0,0,32"
                   TextWrapping="Wrap" TextAlignment="Center" Foreground="#555"/>
        <Button Content="Выйти" Style="{StaticResource PrimaryButton}"
                Width="200" Click="Logout_Click"/>
    </StackPanel>
</Page>
